---
import { getCollection } from 'astro:content';
import BlogPreview from '../components/BlogPreview.astro';
import ContactSection from '../components/ContactSection.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import PublicationList from '../components/PublicationList.astro';
import SectionBlock from '../components/SectionBlock.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { education, experiences, featuredWork, publications, siteMeta, skillGroups } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const featuredPosts = posts.slice(0, 2);
---

<BaseLayout title="André Brandão | Backend Engineer" description={siteMeta.summary}>
  <HeroSection />

  <SectionBlock
    id="experience"
    kicker="Experience"
    title="Shipping backend work across internships, research, and operations-heavy environments."
    intro="The throughline is practical backend engineering: APIs, data flows, messaging, observability, and systems that have to hold up in production."
  >
    <ExperienceTimeline items={experiences} />
  </SectionBlock>

  <SectionBlock
    id="projects"
    kicker="Featured work"
    title="Selected work with a bias for backend depth and reproducible engineering."
    intro="A mix of research artifacts and engineering reports that show how I think about systems, measurement, and implementation detail."
  >
    <ProjectGrid items={featuredWork} />
  </SectionBlock>

  <SectionBlock
    id="publications"
    kicker="Research"
    title="Current publications and academic work."
    intro="Research is where I sharpen measurement, experimental rigor, and long-form technical writing."
  >
    <PublicationList items={publications} />
  </SectionBlock>

  <SectionBlock
    id="skills"
    kicker="Capabilities"
    title="A backend-focused toolkit shaped by services, data, and reliability work."
    intro="These are the technologies and areas that show up most consistently in the work above."
  >
    <div class="project-grid">
      {skillGroups.map((group) => (
        <article class="project-card">
          <header>
            <h3 class="card-title">{group.title}</h3>
          </header>
          <div class="skills-list">
            {group.items.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    id="education"
    kicker="Education"
    title="Formal training grounded in software engineering practice."
    intro="Current academic work is tightly connected to the systems and measurement themes running through the portfolio."
  >
    <div class="education-grid">
      {education.map((item) => (
        <article class="education-card">
          <h3>{item.degree}</h3>
          <p>
            <strong>{item.institution}</strong>
          </p>
          <p>{item.period}</p>
          {item.details && (
            <ul>
              {item.details.map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    id="writing"
    kicker="Writing"
    title="Notes on backend engineering, energy efficiency, and long-term craftsmanship."
    intro="The blog starts small on purpose: a few well-scoped posts, static by design, and easy to maintain."
  >
    <BlogPreview posts={featuredPosts} />
  </SectionBlock>

  <ContactSection />
</BaseLayout>

