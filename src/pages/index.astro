---
import ContactSection from '../components/ContactSection.astro';
import EducationGrid from '../components/EducationGrid.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import ResearchTeaser from '../components/ResearchTeaser.astro';
import SectionBlock from '../components/SectionBlock.astro';
import SkillGroupGrid from '../components/SkillGroupGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  education,
  educationSection,
  experienceSection,
  experiences,
  featuredWork,
  projectsSection,
  researchSection,
  researchTeaserLabel,
  skillGroups,
  skillsSection,
} from '../data/portfolio';
import { siteMeta } from '../data/site';
---

<BaseLayout title="André Brandão | Backend Developer" description={siteMeta.summary}>
  <HeroSection />

  <SectionBlock {...experienceSection}>
    <ExperienceTimeline items={experiences} />
  </SectionBlock>

  <SectionBlock {...projectsSection}>
    <ProjectGrid items={featuredWork} />
  </SectionBlock>

  <SectionBlock {...skillsSection}>
    <SkillGroupGrid items={skillGroups} />
  </SectionBlock>

  <SectionBlock {...educationSection}>
    <EducationGrid items={education} />
  </SectionBlock>

  <SectionBlock {...researchSection}>
    <ResearchTeaser label={researchTeaserLabel} />
  </SectionBlock>

  <ContactSection />
</BaseLayout>
