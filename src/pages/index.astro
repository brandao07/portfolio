---
import ContactSection from '../components/ContactSection.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import PublicationList from '../components/PublicationList.astro';
import SectionBlock from '../components/SectionBlock.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { education, experiences, featuredWork, publications, siteMeta, skillGroups } from '../data/site';
---

<BaseLayout title="André Brandão | Backend Developer" description={siteMeta.summary}>
  <HeroSection />

  <SectionBlock
    id="experience"
    kicker="Experience"
    title="Building backend systems across APIs, data pipelines, observability, and production-oriented internships."
    intro="The common thread is ownership: services, messaging, analytical storage, reliability tooling, and backend work that has to support real usage."
  >
    <ExperienceTimeline items={experiences} />
  </SectionBlock>

  <SectionBlock
    id="projects"
    kicker="Featured work"
    title="Selected engineering case studies from backend delivery and performance work."
    intro="These cards focus on production-oriented systems work rather than research, with a few concrete metrics where they materially show impact."
  >
    <ProjectGrid items={featuredWork} />
  </SectionBlock>

  <SectionBlock
    id="skills"
    kicker="Skills"
    title="A backend-focused toolkit shaped by services, data systems, testing, and observability."
    intro="The emphasis is on tools and concepts that repeatedly appeared across delivery work, not a broad list of everything I have touched."
  >
    <div class="project-grid">
      {skillGroups.map((group) => (
        <article class="project-card">
          <header>
            <h3 class="card-title">{group.title}</h3>
          </header>
          <div class="skills-list">
            {group.items.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    id="education"
    kicker="Education"
    title="Formal training that supports practical software engineering work."
    intro="The academic side stays visible, but the portfolio is intentionally grounded in backend delivery rather than research-first positioning."
  >
    <div class="education-grid">
      {education.map((item) => (
        <article class="education-card">
          <h3>{item.degree}</h3>
          <p>
            <strong>{item.institution}</strong>
          </p>
          <p>{item.period}</p>
          {item.details && (
            <ul>
              {item.details.map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    id="publications"
    kicker="Research"
    title="Publications and academic work."
    intro="Research stays secondary here, but it reflects how I approach measurement, rigor, and long-form technical thinking."
  >
    <PublicationList items={publications} />
  </SectionBlock>

  <ContactSection />
</BaseLayout>
