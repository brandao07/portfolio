---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const tagCounts = posts.reduce<Map<string, number>>((acc, post) => {
  for (const tag of post.data.tags) {
    acc.set(tag, (acc.get(tag) ?? 0) + 1);
  }
  return acc;
}, new Map());

const sortedTags = [...tagCounts.entries()].sort((a, b) => {
  if (b[1] === a[1]) {
    return a[0].localeCompare(b[0]);
  }
  return b[1] - a[1];
});
---

<BaseLayout title="Writing | André Brandão" description="Short notes on backend engineering, research, and systems thinking.">
  <a class="back-link" href={`${import.meta.env.BASE_URL}`}>← Back to portfolio</a>

  <section class="section-card motion-rise">
    <header class="section-head">
      <span class="section-kicker">Archive</span>
      <div class="archive-header">
        <div>
          <h1 class="section-title">Writing</h1>
          <p class="section-intro">
            Short technical notes about backend engineering, software research, and the tradeoffs behind a clean static portfolio.
          </p>
        </div>
      </div>
    </header>

    {sortedTags.length > 0 && (
      <div class="tag-list" aria-label="Tag overview">
        {sortedTags.map(([tag, count]) => (
          <span class="tag">{tag} · {count}</span>
        ))}
      </div>
    )}
  </section>

  <section class="section-card motion-rise">
    <div class="post-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>

