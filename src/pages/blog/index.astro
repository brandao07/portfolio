---
import PostCard from '../../components/PostCard.astro';
import { getBlogPosts, getSortedBlogTags } from '../../data/blog';
import { toSitePath } from '../../lib/site-paths';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getBlogPosts();
const sortedTags = getSortedBlogTags(posts);
---

<BaseLayout title="Writing | André Brandão" description="Short notes on backend engineering, research, and systems thinking.">
  <a class="back-link" href={toSitePath()}>← Back to portfolio</a>

  <section class="section-card motion-rise">
    <header class="section-head">
      <span class="section-kicker">Archive</span>
      <div class="archive-header">
        <div>
          <h1 class="section-title">Writing</h1>
          <p class="section-intro">
            Short technical notes about backend engineering, software research, and the tradeoffs behind a clean static portfolio.
          </p>
        </div>
      </div>
    </header>

    {sortedTags.length > 0 && (
      <div class="tag-list" aria-label="Tag overview">
        {sortedTags.map(([tag, count]) => (
          <span class="tag">{tag} · {count}</span>
        ))}
      </div>
    )}
  </section>

  <section class="section-card motion-rise">
    <div class="post-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
