---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true));

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | André Brandão`} description={post.data.description}>
  <a class="back-link" href={`${import.meta.env.BASE_URL}blog/`}>← Back to writing</a>

  <article class="section-card motion-rise">
    <header class="section-head">
      <span class="section-kicker">Post</span>
      <h1 class="section-title">{post.data.title}</h1>
      <div class="meta-list">
        <time class="card-meta" datetime={post.data.publishDate.toISOString()}>
          {formatDate(post.data.publishDate)}
        </time>
        {post.data.updatedDate && (
          <span class="card-meta">Updated {formatDate(post.data.updatedDate)}</span>
        )}
      </div>
      {post.data.tags.length > 0 && (
        <div class="tag-list" aria-label="Post tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

