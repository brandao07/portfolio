---
import PublicationList from '../components/PublicationList.astro';
import SectionBlock from '../components/SectionBlock.astro';
import { researchPageSection, publications } from '../data/research';
import { toSitePath } from '../lib/site-paths';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Research | André Brandão"
  description="Research, publications, and academic work by André Brandão."
  fillViewport={true}
>
  <a class="button button-secondary back-link" href={toSitePath()}>Back to portfolio</a>

  <SectionBlock {...researchPageSection}>
    <PublicationList items={publications} />
  </SectionBlock>
</BaseLayout>
