---
import Footer from '../components/Footer.astro';
import { navigationItems, siteMeta } from '../data/site';
import { toSitePath } from '../lib/site-paths';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  fillViewport?: boolean;
}

const {
  title = `${siteMeta.displayName} | ${siteMeta.role}`,
  description = siteMeta.summary,
  image = toSitePath('/assets/avatar.png'),
  fillViewport = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#fff7f1" />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" href={image} />
    <link rel="alternate" type="application/rss+xml" title="Andre Brandao RSS Feed" href={toSitePath('/rss.xml')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href={toSitePath()}>{siteMeta.displayName}</a>
        <nav class="nav-links" aria-label="Primary">
          {navigationItems.map((item) => (
            <a href={toSitePath(item.href)}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main id="content" class:list={['page', fillViewport && 'page-fill']}>
      <div class="site-shell">
        <slot />
        <Footer />
      </div>
    </main>
  </body>
</html>
