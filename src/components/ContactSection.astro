---
import { siteMeta, socialLinks } from '../data/site';

const contactFormAction = import.meta.env.PUBLIC_CONTACT_FORM_ACTION?.trim();
const isContactFormEnabled = Boolean(contactFormAction);
---

<section id="contact" class="contact-card motion-rise">
  <div class="contact-layout">
    <div class="contact-copy">
      <div class="contact-head">
        <span class="section-kicker">Contact me</span>
        <h2>Hiring for backend work that needs ownership?</h2>
      </div>
      <p>
        Based in Portugal and open to remote roles or relocation for teams building serious backend systems, APIs, and
        data platforms.
      </p>
      <p class="contact-caption">
        Use the form to send your subject, email, and a short description. I reply directly from{' '}
        <a class="inline-link" href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>.
      </p>
      <div class="contact-links">
        {socialLinks
          .filter((item) => !item.accent)
          .map((item) => (
            <a class="button button-secondary" href={item.href} target="_blank" rel="noreferrer">
              {item.label}
            </a>
          ))}
      </div>
    </div>

    <form class="contact-form" action={contactFormAction} method="POST" data-contact-form>
      <input type="hidden" name="_gotcha" tabindex="-1" autocomplete="off" />
      <label class="form-field">
        <span>Subject</span>
        <input
          type="text"
          name="subject"
          autocomplete="off"
          placeholder="Backend role or project"
          required
        />
      </label>
      <label class="form-field">
        <span>Your email</span>
        <input type="email" name="email" autocomplete="email" placeholder="team@company.com" required />
      </label>
      <label class="form-field">
        <span>Description</span>
        <textarea
          name="message"
          rows="6"
          placeholder="What are you hiring for, what stage is the team at, and what would ownership look like?"
          required
        ></textarea>
      </label>
      <button class="button button-primary" type="submit" disabled={!isContactFormEnabled} data-submit-button>
        Send message
      </button>
      {isContactFormEnabled ? (
        <p class="contact-form-meta" data-form-hint>Submissions go straight to my inbox.</p>
      ) : (
        <p class="contact-form-meta contact-form-meta-muted">
          Set <code>PUBLIC_CONTACT_FORM_ACTION</code> to your form endpoint to enable website submissions.
        </p>
      )}
    </form>
  </div>
</section>

<script>
  const form = document.querySelector('[data-contact-form]');
  const submitButton = document.querySelector('[data-submit-button]');
  const formHint = document.querySelector('[data-form-hint]');
  const defaultButtonLabel = submitButton?.textContent ?? 'Send message';
  const defaultHint = formHint?.textContent ?? '';

  if (form instanceof HTMLFormElement && submitButton instanceof HTMLButtonElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
      if (formHint) {
        formHint.textContent = 'Submitting your message...';
        formHint.classList.remove('is-success', 'is-error');
      }

      try {
        const response = await fetch(form.action, {
          method: form.method,
          body: new FormData(form),
          headers: {
            Accept: 'application/json',
          },
        });

        if (response.ok) {
          form.reset();
          if (formHint) {
            formHint.textContent = 'Message sent. I will get back to you directly by email.';
            formHint.classList.add('is-success');
          }
          return;
        }

        const data = await response.json().catch(() => null);
        const message =
          data && Array.isArray(data.errors) && data.errors.length > 0
            ? data.errors.map((error) => error.message).join(', ')
            : 'There was a problem sending your message. Please try again.';

        if (formHint) {
          formHint.textContent = message;
          formHint.classList.add('is-error');
        }
      } catch {
        const message = 'Network error. Please try again in a moment.';
        if (formHint) {
          formHint.textContent = message;
          formHint.classList.add('is-error');
        }
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = defaultButtonLabel;
        if (formHint && formHint.textContent === 'Submitting your message...') {
          formHint.textContent = defaultHint;
          formHint.classList.remove('is-success', 'is-error');
        }
      }
    });
  }
</script>
