---
import { siteMeta, socialLinks } from '../data/site';
---

<section id="contact" class="contact-card motion-rise">
  <h2>Build something that needs strong backend systems work.</h2>
  <p>
    Based in Portugal, I am open to backend roles, remote work, and relocation for teams doing serious work in APIs,
    data systems, observability, and production reliability.
  </p>
  <div class="cta-row">
    <a class="button button-primary" href={`mailto:${siteMeta.email}`}>Email me</a>
    {socialLinks
      .filter((item) => !item.accent)
      .map((item) => (
        <a class="button button-secondary" href={item.href} target="_blank" rel="noreferrer">
          {item.label}
        </a>
      ))}
  </div>
</section>
