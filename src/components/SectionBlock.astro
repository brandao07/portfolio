---
interface Props {
  id: string;
  kicker: string;
  title: string;
  intro?: string;
}

const { id, kicker, title, intro } = Astro.props;
---

<section id={id} class="section-card motion-rise">
  <header class="section-head">
    <span class="section-kicker">{kicker}</span>
    <h2 class="section-title">{title}</h2>
    {intro && <p class="section-intro">{intro}</p>}
  </header>
  <slot />
</section>

