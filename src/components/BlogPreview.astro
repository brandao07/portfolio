---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="archive-header">
  <p class="section-intro">A small writing archive focused on backend engineering, reliability, and research notes.</p>
  <a class="button button-secondary" href={`${base}blog/`}>Open archive</a>
</div>
<div class="post-grid">
  {posts.map((post) => (
    <PostCard post={post} />
  ))}
</div>

