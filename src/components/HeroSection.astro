---
import { focusAreas, heroStats, siteMeta, socialLinks } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <article class="hero-panel motion-rise">
    <div class="hero-content">
      <span class="eyebrow">Open to backend roles</span>
      <p class="hero-role">{siteMeta.role}</p>
      <h1 class="display">{siteMeta.title}</h1>
      <p class="lead">{siteMeta.summary}</p>
      <div class="chip-list" aria-label="Focus areas">
        {focusAreas.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
      <div class="cta-row">
        <a class="button button-primary" href={`mailto:${siteMeta.email}`}>Start a conversation</a>
        <a class="button button-secondary" href={`${base}blog/`}>Read the blog</a>
      </div>
      <div class="hero-stats">
        {heroStats.map((item) => (
          <div class="stat-card">
            <span class="stat-value">{item.value}</span>
            <span class="stat-label">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </article>
  <aside class="hero-aside motion-rise">
    <div class="portrait">
      <img src={`${base}assets/avatar.png`} alt="Portrait of André Brandão" />
    </div>
    <div class="aside-card">
      <h2>Now</h2>
      <p>{siteMeta.availability}</p>
    </div>
    <div class="aside-card">
      <h2>Links</h2>
      <div class="link-row">
        {socialLinks.map((item) => (
          <a class="pill-link" href={item.href} target="_blank" rel="noreferrer">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </aside>
</section>
