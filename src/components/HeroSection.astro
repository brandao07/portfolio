---
import {
  currentStack,
  currentStackNote,
  expandingInto,
  expandingIntoNote,
  focusAreas,
  heroAvailabilityMeta,
  heroStats,
  siteMeta,
} from '../data/site';

const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <article class="hero-panel motion-rise">
    <div class="hero-content">
      <div class="hero-heading">
        <span class="eyebrow">Open to backend roles</span>
        <p class="hero-role">{siteMeta.role}</p>
        <h1 class="display">{siteMeta.title}</h1>
      </div>
      <p class="lead">{siteMeta.summary}</p>
      <div class="chip-list" aria-label="Focus areas">
        {focusAreas.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
      <div class="cta-row">
        <a class="button button-primary" href={`${base}#contact`}>Start a conversation</a>
        <a class="button button-secondary" href={`${base}#projects`}>View featured work</a>
      </div>
      <div class="hero-stats">
        {heroStats.map((item) => (
          <a class="stat-card stat-link" href={`${base}#${item.targetId}`} data-case-study-link>
            <span class="stat-value">{item.value}</span>
            <span class="stat-label">{item.label}</span>
          </a>
        ))}
      </div>
    </div>
  </article>
  <aside class="hero-aside motion-rise">
    <div class="portrait">
      <img src={`${base}assets/avatar.png`} alt="Portrait of André Brandão" />
    </div>
    <div class="aside-card">
      <h2>Now</h2>
      <p>{siteMeta.availability}</p>
      <dl class="aside-meta-list">
        {heroAvailabilityMeta.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>
    <div class="aside-card">
      <h2>Currently working with</h2>
      <div class="aside-chip-list" aria-label="Current stack">
        {currentStack.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
      <p class="aside-note">{currentStackNote}</p>
    </div>
    <div class="aside-card">
      <h2>Expanding into</h2>
      <div class="aside-chip-list" aria-label="Expanding into">
        {expandingInto.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
      <p class="aside-note">{expandingIntoNote}</p>
    </div>
  </aside>
</section>
