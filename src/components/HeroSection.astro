---
import {
  focusAreas,
  heroAsideCards,
  heroEyebrow,
  heroStats,
} from '../data/portfolio';
import { siteMeta } from '../data/site';
import { toSitePath } from '../lib/site-paths';
---

<section class="hero">
  <article class="hero-panel motion-rise">
    <div class="hero-content">
      <div class="hero-heading">
        <span class="eyebrow">{heroEyebrow}</span>
        <p class="hero-role">{siteMeta.role}</p>
        <h1 class="display">{siteMeta.headline}</h1>
      </div>
      <p class="lead">{siteMeta.summary}</p>
      <div class="chip-list" aria-label="Focus areas">
        {focusAreas.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
      <div class="cta-row">
        <a class="button button-primary" href={toSitePath('#contact')}>Start a conversation</a>
        <a class="button button-secondary" href={toSitePath('#projects')}>View featured work</a>
      </div>
      <div class="hero-stats">
        {heroStats.map((item) => (
          <a class="stat-card stat-link" href={toSitePath(`#${item.targetId}`)} data-case-study-link>
            <span class="stat-value">{item.value}</span>
            <span class="stat-label">{item.label}</span>
          </a>
        ))}
      </div>
    </div>
  </article>
  <aside class="hero-aside motion-rise">
    <div class="portrait">
      <img src={toSitePath('/assets/avatar.png')} alt="Portrait of André Brandão" />
    </div>
    {heroAsideCards.map((card) => (
      <div class="aside-card">
        <h2>{card.title}</h2>
        {card.description && <p>{card.description}</p>}
        {card.meta && (
          <dl class="aside-meta-list">
            {card.meta.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        )}
        {card.chips && (
          <div class="aside-chip-list" aria-label={card.chipLabel ?? card.title}>
            {card.chips.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>
        )}
        {card.note && <p class="aside-note">{card.note}</p>}
      </div>
    ))}
  </aside>
</section>
