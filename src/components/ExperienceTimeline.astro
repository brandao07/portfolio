---
import type { ExperienceEntry } from '../data/portfolio';
import ResourceLinks from './ResourceLinks.astro';

interface Props {
  items: ExperienceEntry[];
}

const { items } = Astro.props;
---

<div class="timeline">
  {items.map((item) => (
    <article class="timeline-item">
      <header>
        <div class="title-row">
          <h3 class="entry-title">
            <a href={item.href} target="_blank" rel="noreferrer">
              {item.role} · {item.company}
            </a>
          </h3>
          <span class="entry-period">{item.period}</span>
        </div>
      </header>
      <p set:html={item.summary}></p>
      <div class="chip-list" aria-label={`${item.company} technologies`}>
        {item.technologies.map((tech) => (
          <span class="chip">{tech}</span>
        ))}
      </div>
      <ResourceLinks items={item.links} />
    </article>
  ))}
</div>
