---
import type { ProjectEntry } from '../data/site';

interface Props {
  items: ProjectEntry[];
}

const { items } = Astro.props;
const base = import.meta.env.BASE_URL;
const resolveHref = (href: string) => (href.startsWith('/') ? `${base}${href.slice(1)}` : href);
---

<div class="project-grid">
  {items.map((item) => (
    <article class="project-card" id={item.id}>
      {(() => {
        const metrics = item.metrics?.length ? item.metrics : [{ value: item.metric, label: item.metricLabel }];

        return (
      <header>
        <h3 class="card-title">{item.title}</h3>
        <div class="metric-row" aria-label={`${item.title} key metrics`}>
          {metrics.map((metric) => (
            <div class="metric-card" aria-label={metric.label}>
              <span class="metric-value">{metric.value}</span>
              <span class="metric-label">{metric.label}</span>
            </div>
          ))}
        </div>
        <p class="case-study-context">{item.context}</p>
      </header>
        );
      })()}
      <div class="case-study-grid">
        <article class="case-study-block">
          <h4 class="case-study-label">Problem</h4>
          <p>{item.problem}</p>
        </article>
        <article class="case-study-block">
          <h4 class="case-study-label">Work</h4>
          <p>{item.work}</p>
        </article>
        <article class="case-study-block">
          <h4 class="case-study-label">Result</h4>
          <p>{item.result}</p>
        </article>
      </div>
      <div class="tag-list" aria-label={`${item.title} tags`}>
        {item.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      {item.links && item.links.length > 0 && (
        <div class="inline-links">
          {item.links.map((link) => (
            <a class="inline-link" href={resolveHref(link.href)} target="_blank" rel="noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      )}
    </article>
  ))}
</div>

<script>
  const highlightDurationMs = 1500;
  let activeCard;
  let activeTimeoutId;

  const clearHighlight = () => {
    if (!(activeCard instanceof HTMLElement)) return;
    activeCard.classList.remove('is-highlighted');
    activeCard = undefined;
  };

  const highlightCard = (card) => {
    if (!(card instanceof HTMLElement)) return;

    window.clearTimeout(activeTimeoutId);
    clearHighlight();

    activeCard = card;
    card.classList.remove('is-highlighted');
    void card.offsetWidth;
    card.classList.add('is-highlighted');

    activeTimeoutId = window.setTimeout(() => {
      if (activeCard === card) {
        card.classList.remove('is-highlighted');
        activeCard = undefined;
      }
    }, highlightDurationMs);
  };

  const scrollToCaseStudy = (id, smooth = true) => {
    if (!id) return;

    const card = document.getElementById(id);
    if (!(card instanceof HTMLElement)) return;

    card.scrollIntoView({
      behavior: smooth ? 'smooth' : 'auto',
      block: 'start',
    });
    highlightCard(card);
  };

  document.querySelectorAll('[data-case-study-link]').forEach((link) => {
    if (!(link instanceof HTMLAnchorElement)) return;

    link.addEventListener('click', (event) => {
      const targetId = new URL(link.href).hash.replace('#', '');
      if (!targetId) return;

      event.preventDefault();
      scrollToCaseStudy(targetId, true);
    });
  });

  if (window.location.hash.startsWith('#case-study-')) {
    const initialId = window.location.hash.slice(1);
    window.requestAnimationFrame(() => {
      scrollToCaseStudy(initialId, false);
      window.history.replaceState({}, '', `${window.location.pathname}${window.location.search}`);
    });
  }
</script>
