---
import type { ProjectEntry } from '../data/site';

interface Props {
  items: ProjectEntry[];
}

const { items } = Astro.props;
const base = import.meta.env.BASE_URL;
const resolveHref = (href: string) => (href.startsWith('/') ? `${base}${href.slice(1)}` : href);
---

<div class="project-grid">
  {items.map((item) => (
    <article class="project-card">
      <header>
        <h3 class="card-title">{item.title}</h3>
      </header>
      <p>{item.description}</p>
      {item.highlights && item.highlights.length > 0 && (
        <ul class="project-highlights">
          {item.highlights.map((highlight) => (
            <li set:html={highlight}></li>
          ))}
        </ul>
      )}
      <div class="tag-list" aria-label={`${item.title} tags`}>
        {item.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      {item.links && item.links.length > 0 && (
        <div class="inline-links">
          {item.links.map((link) => (
            <a class="inline-link" href={resolveHref(link.href)} target="_blank" rel="noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      )}
    </article>
  ))}
</div>
